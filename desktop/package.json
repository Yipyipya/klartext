{
  "name": "klartext-desktop",
  "version": "0.1.1",
  "private": true,
  "description": "Klartext Desktop – systemweites Diktat per globalem Shortcut, Text landet direkt an der Cursor-Position",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icon": "node make-icon.js",
    "dist": "electron-builder --mac dmg",
    "dist:win": "electron-builder --win nsis --x64"
  },
  "build": {
    "appId": "app.klartext.desktop",
    "productName": "Klartext",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "pill.html",
      "keywin.html",
      "icon.png"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Klartext nutzt dein Mikrofon zum Diktieren.",
        "LSUIElement": true
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Klartext"
    }
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0"
  }
}
